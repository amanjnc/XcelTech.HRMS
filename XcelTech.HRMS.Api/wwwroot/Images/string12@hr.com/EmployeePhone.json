{
  "openapi": "3.0.1",
  "info": {
    "title": "XcelTech.HRMS.Api",
    "version": "1.0"
  },
  "paths": {
    "/api/Account/Register": {
      "post": {
        "tags": [
          "Account"
        ],
        "requestBody": {
          "content": {
            "application/json-patch+json": {
              "schema": {
                "$ref": "#/components/schemas/DtoRegister"
              }
            },
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DtoRegister"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/DtoRegister"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/DtoRegister"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },




    "/api/Account/login": {
      "post": {
        "tags": [
          "Account"
        ],
        "requestBody": {
          "content": {
            "application/json-patch+json": {
              "schema": {
                "$ref": "#/components/schemas/DtoToLogin"
              }
            },
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DtoToLogin"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/DtoToLogin"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/DtoToLogin"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    }
  },




  "components": {
    "schemas": {
      "DateOnly": {
        "type": "object",
        "properties": {
          "year": {
            "type": "integer",
            "format": "int32"
          },
          "month": {
            "type": "integer",
            "format": "int32"
          },
          "day": {
            "type": "integer",
            "format": "int32"
          },
          "dayOfWeek": {
            "$ref": "#/components/schemas/DayOfWeek"
          },
          "dayOfYear": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "dayNumber": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          }
        },
        "additionalProperties": false
      },
      "DayOfWeek": {
        "enum": [
          0,
          1,
          2,
          3,
          4,
          5,
          6
        ],
        "type": "integer",
        "format": "int32"
      },
      "DtoRegister": {
        "required": [
          "employeeEmail",
          "employeeName",
          "password"
        ],
        "type": "object",
        "properties": {
          "employeeName": {
            "minLength": 1,
            "type": "string"
          },
          "employeeEmail": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "DtoToLogin": {
        "required": [
          "employeeEmail",
          "password"
        ],
        "type": "object",
        "properties": {
          "employeeEmail": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },

      
      "Employee": {
        "type": "object",
        "properties": {
          "employeeId": {
            "type": "integer",
            "format": "int32"
          },
          "employeeName": {
            "type": "string",
            "nullable": true
          },
          "employeeAge": {
            "type": "integer",
            "format": "int32"
          },
          "employyDOB": {
            "$ref": "#/components/schemas/DateOnly"
          },
          "employeeHiredDate": {
            "$ref": "#/components/schemas/DateOnly"
          },
          "employeeAddress": {
            "type": "string",
            "nullable": true
          },
          "employeePhone": {
            "type": "integer",
            "format": "int32"
          },
          "employeeEmail": {
            "type": "string",
            "nullable": true
          },
          "departmentId": {
            "type": "integer",
            "format": "int32"
          },
          "department": {
            "$ref": "#/components/schemas/Department"
          },
          "project": {
            "$ref": "#/components/schemas/Project"
          },
          "payrollId": {
            "type": "integer",
            "format": "int32"
          },
          "payroll": {
            "$ref": "#/components/schemas/Payroll"
          }
        },
        "additionalProperties": false
      }
    }
  }
}